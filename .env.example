# ─── Banco de dados ────────────────────────────────────────────────
# Postgres do projeto. O schema "clinicaos" e usado para isolar este app
# de outras coisas no mesmo cluster.
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=clinicaos"

# ─── NextAuth ──────────────────────────────────────────────────────
# URL onde o app esta rodando (use http://localhost:3001 em dev).
NEXTAUTH_URL="https://clinica-saas-clinica-os.vercel.app"
# Segredo para assinar o JWT. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-um-segredo-aleatorio"

# ─── Supabase Storage (arquivos: receitas, exames) ────────────────
SUPABASE_URL="https://SEU_PROJETO.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role_key_secreta"
SUPABASE_BUCKET="clinicaos-files"
